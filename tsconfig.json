{
  "compilerOptions": {

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,

    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true

  },
  "include": ["frontend/src", "backend/src"],
  "exclude": ["node_modules", "dist"]
}
